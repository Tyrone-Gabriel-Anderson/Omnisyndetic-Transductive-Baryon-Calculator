  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>E\u2080</b> \u2014 <color=#BFA0FF>Rest-energy interval from \u03BB</color>\r\n<i>Ledger-assigned
    bracket derived from six-site closure</i>\r\n<color=#9AA3B2>Each certified arc-seat
    \u27E8L, U\u27E9 maps to a fixed interval [Emin, Emax] under one global reporting
    scale.</color>\r\n<color=#8FCFC8>The admitted \u03BB interval for the certified
    seat determines the corresponding rest-energy interval. In empirical comparison,
    this is the baryon rest-mass band in MeV.</color>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5302535af1044152a457ed104f1f4b91, type: 2}
